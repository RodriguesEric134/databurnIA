lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these written to a standalone folder, but may contain files we don't want to commit
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

